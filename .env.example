# rbxlAnimate runs as a static export on GitHub Pages.
# No server secrets are required for the demo (client-side auth + generation).
#
# For local preview of the Pages build (with /RbxlAnimate basePath):
#   set GITHUB_PAGES=true
#   npm run build
#
# Real Stripe / OAuth later will need a backend — not used on static Pages.
# Optional UI flags (polished “keys detected” state on /login — still no real OAuth on Pages):
# NEXT_PUBLIC_GITHUB_OAUTH=true
# NEXT_PUBLIC_GOOGLE_OAUTH=true
# NEXT_PUBLIC_ROBLOX_OAUTH=true
